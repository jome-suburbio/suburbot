# ID del Google Sheet. Lo encuentras en la URL:
# https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=

# Nombre exacto de la pestaña donde esta la matriz de disponibilidad.
GOOGLE_SHEETS_TAB_NAME=Disponibilidad

# Opcion A: ruta local al JSON de una cuenta de servicio de Google Cloud.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# Opcion B: JSON completo de la cuenta de servicio en una sola variable.
# Si usas esta opcion, no necesitas GOOGLE_APPLICATION_CREDENTIALS.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
